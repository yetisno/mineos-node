FROM ubuntu:26.04 AS build
LABEL MAINTAINER='William Dizon <wdchromium@gmail.com>'

#set build directory
WORKDIR /build
ENV NODE_VERSION=14.21.3

#install necessary build dependencies
ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
  curl \
  xz-utils \
  ca-certificates \
  python3 \
  python3-setuptools \
  build-essential \
  && node_arch="$(dpkg --print-architecture)" \
  && case "$node_arch" in amd64) node_arch=x64 ;; arm64) node_arch=arm64 ;; armhf) node_arch=armv7l ;; *) echo "Unsupported architecture: $node_arch" >&2; exit 1 ;; esac \
  && curl -fsSL https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${node_arch}.tar.xz \
  | tar -xJ -C /usr/local --strip-components=1 \
  && ln -sf /usr/local/bin/node /usr/bin/node \
  && npm install -g npm@8.19.4

# copy package manifests and install dependencies with npm ci
# by copying package manifests first we stop changes in other files from triggering a rebuild of this image stage
COPY package.json package-lock.json /build/
RUN npm ci

#copy other files to build dir
COPY . /build

#final image
FROM ubuntu:26.04

WORKDIR /usr/games/minecraft
ENV NODE_VERSION=14.21.3

#install necessary run dependencies
ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
  rdiff-backup \
  screen \
  rsync \
  git \
  curl \
  rlwrap \
  xz-utils \
  ca-certificates \
  openjdk-26-jre-headless \
  openjdk-8-jre-headless \
  ca-certificates-java \
  && node_arch="$(dpkg --print-architecture)" \
  && case "$node_arch" in amd64) node_arch=x64 ;; arm64) node_arch=arm64 ;; armhf) node_arch=armv7l ;; *) echo "Unsupported architecture: $node_arch" >&2; exit 1 ;; esac \
  && curl -fsSL https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${node_arch}.tar.xz \
  | tar -xJ -C /usr/local --strip-components=1 \
  && ln -sf /usr/local/bin/node /usr/bin/node \
  && apt-get autoremove -y \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

COPY --from=build /build /usr/games/minecraft
RUN cp /usr/games/minecraft/mineos.conf /etc/mineos.conf \
  && cp /usr/games/minecraft/entrypoint.sh /entrypoint.sh

#set start command and entrypoint
CMD ["node", "webui.js"]
ENTRYPOINT ["/entrypoint.sh"]

#set image ports volumes and envs
EXPOSE 8443 25565-25570
VOLUME /var/games/minecraft
VOLUME /etc/ssl/certs
ENV USER_PASSWORD=random_see_log USER_NAME=mc USER_UID=1000 USE_HTTPS=true SERVER_PORT=8443
